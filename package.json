{
  "name": "mytronome",
  "private": true,
  "version": "1.0.0",
  "description": "A cross-platform metronome. Accurate client-side tick; presets with local/cloud/server storage.",
  "workspaces": [
    "metronome-engine",
    "presets",
    "web",
    "desktop"
  ],
  "scripts": {
    "test": "tsc --noEmit -p tsconfig.test.json && vitest run",
    "test:watch": "vitest",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "deploy:web": "npm run build -w web && node scripts/deploy-web.mjs",
    "bump:major": "node scripts/bumpVersion.mjs --major",
    "bump:minor": "node scripts/bumpVersion.mjs --minor",
    "bump:patch": "node scripts/bumpVersion.mjs --patch",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.5",
    "ssh2-sftp-client": "^12.1.1",
    "typescript": "~6.0.2",
    "vitest": "^3.2.4"
  }
}
