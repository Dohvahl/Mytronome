{
  "name": "mytronome",
  "private": true,
  "version": "0.0.0",
  "description": "A cross-platform metronome. Accurate client-side tick; presets with local/cloud/server storage.",
  "workspaces": [
    "metronome-engine",
    "presets",
    "web",
    "desktop"
  ],
  "scripts": {
    "test": "tsc --noEmit -p tsconfig.test.json && vitest run",
    "test:watch": "vitest",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.5",
    "typescript": "~6.0.2",
    "vitest": "^3.2.4"
  }
}
